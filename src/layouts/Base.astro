---
/**
 * Base.astro — Growtharchers base layout
 * All pages extend this layout. Pass title, description, and optional
 * ogImage as props. Structured data (JSON-LD) is rendered server-side
 * for perfect Google crawlability.
 */
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  type?: 'website' | 'article';
  publishDate?: string;
}

const {
  title = 'Growtharchers — When Commerce Strategy Needs to Become Commerce Impact.',
  description = 'The intelligent commerce advisory that embeds a Chief Commerce Officer alongside your leadership team and shares P&L accountability for the result. 12P™ Framework · 6 Commerce Fits · Three Horizons.',
  ogImage = '/og-default.jpg',
  canonical = Astro.url.href,
  type = 'website',
  publishDate,
} = Astro.props;

const siteName = 'Growtharchers';
const twitterHandle = '@growtharchers';

// JSON-LD structured data — helps Google rich results
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Growtharchers Consulting LLP',
  alternateName: 'Growtharchers',
  description,
  url: 'https://growtharchers.com',
  logo: 'https://growtharchers.com/logo.svg',
  foundingDate: '2024',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Mumbai',
    addressRegion: 'Maharashtra',
    addressCountry: 'IN',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'hello@growtharchers.com',
    contactType: 'Business Enquiries',
  },
  sameAs: [
    'https://linkedin.com/company/growtharchers',
  ],
  knowsAbout: [
    '12P Intelligent Commerce Framework',
    'Commerce Strategy',
    'Fractional CCO',
    'Omnichannel Commerce',
    'D2C Strategy',
    'Marketplace Strategy',
    'Commerce Transformation',
  ],
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Robots -->
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />

  <!-- Open Graph (LinkedIn, WhatsApp, Facebook) -->
  <meta property="og:type" content={type} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_IN" />

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content={twitterHandle} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

  {publishDate && <meta property="article:published_time" content={publishDate} />}

  <!-- Performance: preconnect to font origin -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Theme colour (browser chrome on mobile) -->
  <meta name="theme-color" content="#0E1018" />

  <!-- Structured data (JSON-LD) — rendered as static HTML, fully crawlable -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

  <!-- Additional head content injected by individual pages -->
  <slot name="head" />
</head>

<body>
  <Nav />

  <main>
    <slot />
  </main>

  <Footer />

  <!-- Site-wide interaction script — defer until after paint -->
  <script>
    // Segment selector (Hero)
    function selectSeg(id: string, btn: HTMLElement) {
      document.querySelectorAll('.seg-pill').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.seg-msg').forEach(m => m.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('smsg-' + id)?.classList.add('active');
    }

    // Framework tab switcher
    function showFW(id: string, btn: HTMLElement) {
      document.querySelectorAll('.fw-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.fw-tab').forEach(t => t.classList.remove('active'));
      document.getElementById('fwp-' + id)?.classList.add('active');
      btn.classList.add('active');
      document.querySelectorAll('#fwp-' + id + ' .reveal').forEach(el => {
        el.classList.remove('visible');
        setTimeout(() => el.classList.add('visible'), 50);
      });
    }

    // 12P pillar selector
    function selectPillar(id: string, btn: HTMLElement) {
      document.querySelectorAll('.p12-ptab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.p12-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('pp-' + id)?.classList.add('active');
    }

    // Expose to inline onclick handlers
    (window as any).selectSeg = selectSeg;
    (window as any).showFW = showFW;
    (window as any).selectPillar = selectPillar;

    // Scroll-reveal animation
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          setTimeout(() => e.target.classList.add('visible'), 60);
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.07, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

    // Staggered card reveals
    document.querySelectorAll('.cap-grid,.engage-cards,.founders-grid,.cf-grid,.exp-trio,.commitments-grid,.diff-grid').forEach(parent => {
      parent.querySelectorAll('.reveal,.cap-card,.eng-card,.founder-card,.cf-card,.et-item,.cmt-item,.dg-item').forEach((el, i) => {
        (el as HTMLElement).style.transitionDelay = (i * 70) + 'ms';
      });
    });

    // Active nav link on scroll
    const secs = document.querySelectorAll('section[id]');
    const nls = document.querySelectorAll('.nav-links a');
    window.addEventListener('scroll', () => {
      let cur = '';
      secs.forEach(s => { if (window.scrollY >= (s as HTMLElement).offsetTop - 120) cur = s.id; });
      nls.forEach(a => {
        (a as HTMLElement).style.color = a.getAttribute('href')?.includes(cur) ? 'var(--gold)' : '';
      });
    }, { passive: true });
  </script>
</body>
</html>
